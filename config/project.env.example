# Copy this file to config/project.env and update the values for your system.

BASE_DIR=/absolute/path/to/Genetic_Data
KEEP_SAMPLES_FILE=/absolute/path/to/keep_samples_ipnr.txt

PLINK_BIN=plink1.9
GCTA_BIN=gcta64

FILTERED_DIR=/absolute/path/to/filtered_data
MERGED_DIR=/absolute/path/to/filtered_data/merged_final

LD_PRUNED_PREFIX=/absolute/path/to/merged_LDpruned
MERGED_GWAS_PREFIX=/absolute/path/to/merged_final_nodupPos
GRM_PREFIX=/absolute/path/to/GRM_full
SPARSE_GRM_PREFIX=/absolute/path/to/GRM_sparse

PHENO_FILE=/absolute/path/to/pheno_LSADT.txt
COVAR_FILE=/absolute/path/to/covar_LSADT.txt
GWAS_OUT_PREFIX=/absolute/path/to/GWAS_LSADT

INFO_THRESHOLD=0.8
MAF_THRESHOLD=0.01
GENO_THRESHOLD=0.02
HWE_THRESHOLD=1e-6
